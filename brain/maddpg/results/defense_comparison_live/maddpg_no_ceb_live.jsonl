{"question_id": "Q006", "question": "How does BERT's masked language model objective differ from next sentence prediction?", "ground_truth": "Masked language modeling predicts masked tokens from context within the input, while next sentence prediction trains the model to decide whether sentence B truly follows sentence A.", "category": "intra_paper_comparison", "difficulty": "medium", "policy": "maddpg_no_ceb", "data_source": "live_llm", "final_status": "rejected", "final_answer": "BERT's masked language model objective differs from next sentence prediction in that it predicts every token, whereas MLM (masked language model) converges marginally slower but has empirical improvements that outweigh the increased training cost.", "token_f1": 0.3333, "rouge_l": 0.2258, "correctness": 0.3333, "faithfulness": 0.0, "citation_support": 0.0, "source_precision": 1.0, "source_recall": 1.0, "verification_pass": 0, "unsupported_claims": 1, "latency_seconds": 81.3344, "num_llm_calls": 7, "token_usage": 3891, "num_steps": 10, "trace": [{"step": 1, "agent": "retriever", "action": "hybrid_rerank", "params": {"dense_sparse_weight": 0.48679533787071705, "top_k": 23, "rerank_threshold": 0.2651537358760834, "source_diversity": 0.3653858155012131}, "reward": -0.109, "done": false}, {"step": 2, "agent": "grader", "action": "medium_filter", "params": {"relevance_threshold": 0.5410119481384754, "evidence_keep_ratio": 0.19136911630630493, "strictness_score": 0.6485932320356369}, "reward": -0.3027, "done": false}, {"step": 3, "agent": "generator", "action": "generate_with_strict_citations", "params": {"temperature": 0.23687675595283508, "citation_strictness": 0.7751266360282898, "max_tokens": 881, "answer_detail_level": 0.5270596407353878}, "reward": -0.3242, "done": false}, {"step": 4, "agent": "verifier", "action": "verify_answer", "params": {"support_threshold": 0.7201422303915024, "confidence_threshold": 0.5192230027168989}, "reward": -0.37, "done": false}, {"step": 5, "agent": "verifier"