{"question_id": "Q002", "question": "How does Kachru's concentric circles model distinguish between the Inner, Outer, and Expanding circles?", "ground_truth": "The Inner circle refers to native speakers of English as a first language. The Outer circle refers to countries where English became an official second language, often through colonial history. The Expanding circle refers to places where English is mainly used as a foreign or international language.", "category": "direct_fact_lookup", "difficulty": "easy", "policy": "maddpg_ceb", "data_source": "live_llm", "final_status": "error", "final_answer": "", "token_f1": 0.0, "rouge_l": 0.0, "correctness": 0.0, "faithfulness": 0.0, "citation_support": 0.0, "source_precision": 0.0, "source_recall": 0.0, "verification_pass": 0, "unsupported_claims": 0, "latency_seconds": 18.3083, "num_llm_calls": 0, "token_usage": 0, "num_steps": 1, "trace": [{"step": 1, "agent": "retriever", "action": "hybrid_rerank", "params": {"dense_sparse_weight": 0.5317429527640343, "top_k": 18, "rerank_threshold": 0.7265229374170303, "source_diversity": 0.27578504383563995}, "reward": -0.1415, "done": false}, {"agent": "grader", "error": "Failed after 10 retries due to rate limits."}]}
